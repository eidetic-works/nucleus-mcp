{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.eidetic-works/nucleus",
  "description": "Sovereign Agent OS — Persistent Memory, Governance & Compliance for AI Agents.",
  "repository": {
    "url": "https://github.com/eidetic-works/nucleus-mcp",
    "source": "github"
  },
  "websiteUrl": "https://nucleusos.dev",
  "version": "1.15.2",
  "tags": [
    "memory",
    "agent-memory",
    "governance",
    "compliance",
    "persistent-context",
    "mcp",
    "ai-agents",
    "sovereign"
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://relay.nucleusos.dev/mcp"
    }
  ],
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "nucleus-mcp",
      "version": "1.15.2",
      "runtimeHint": "uvx",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Path to .brain/ directory (defaults to .brain in current directory)",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "NUCLEUS_BRAIN_PATH"
        }
      ]
    }
  ]
}
