{
  "manifest_version": "0.4",
  "name": "nucleus-mcp",
  "display_name": "Nucleus MCP",
  "version": "1.15.2",
  "description": "The portable decision log your AI tools all read - persistent memory, task orchestration, governance, and execution verification across every session.",
  "author": {
    "name": "eidetic-works"
  },
  "homepage": "https://github.com/eidetic-works/nucleus-mcp",
  "documentation": "https://github.com/eidetic-works/nucleus-mcp#readme",
  "server": {
    "type": "uv",
    "entry_point": "src/server.py",
    "mcp_config": {
      "command": "uv",
      "args": ["run", "--directory", "${__dirname}", "src/server.py"]
    }
  },
  "compatibility": {
    "platforms": ["darwin", "linux", "win32"],
    "runtimes": {
      "python": ">=3.10"
    }
  },
  "keywords": ["mcp", "memory", "agents", "governance", "nucleus"],
  "license": "MIT"
}
